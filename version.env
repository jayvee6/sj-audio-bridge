# Consumed by Scripts/package_app.sh + sign-and-notarize.sh (sourced).
MARKETING_VERSION=0.1.0
BUILD_NUMBER=1

# App identity
APP_NAME=SJAudioBridge
BUNDLE_ID=dev.studiojoe.sjaudiobridge

# Menubar app → emits LSUIElement=true in Info.plist (no Dock icon).
MENU_BAR_APP=1

# Signing (Developer ID Application, already in keychain) + notarization
# keychain profile (stored via `xcrun notarytool store-credentials`).
SIGN_IDENTITY="Developer ID Application: Jose Villarreal (ATGGQ68RUK)"
# package_app.sh reads APP_IDENTITY (alias). Stable Developer ID signing keeps
# the macOS Screen-Recording TCC grant from re-prompting every rebuild, and
# matches the hardened-runtime build that B8 notarizes.
APP_IDENTITY="Developer ID Application: Jose Villarreal (ATGGQ68RUK)"
SIGNING_MODE="identity"
NOTARY_PROFILE="sj-audio-bridge-notary"
TEAM_ID="ATGGQ68RUK"
